NODE_ENV=production
PORT=3000

# Express verifies webhooks using this shared secret
GITHUB_SECRET=change_me_webhook_secret

# GitHub token used for REST API (comments + commit statuses)
GITHUB_TOKEN=change_me_github_token

# Gemini API key for TP/FP classification
GEMINI_API_KEY=change_me_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# Redis for BullMQ
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

QUEUE_NAME=axis-security-gate
WORKER_CONCURRENCY=2
LOG_LEVEL=info

# Semgrep ruleset (example). Override for your environment/language.
SEMGREP_CONFIG=p/default
SEMGREP_TIMEOUT_MS=180000

# Context extraction for flagged lines
CONTEXT_WINDOW_LINES=10
AI_MAX_CONTEXT_CHARS=12000
MAX_SEMGREP_FINDINGS=25
MAX_GITLEAKS_FINDINGS=25
MAX_NPM_AUDIT_FINDINGS=25

# Risk policy
BLOCK_CONFIDENCE_THRESHOLD=80
GITHUB_CONTEXT=axis-security

